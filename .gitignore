# ---
# Runtime artefacts (generated by MTA:SA server on resource start).
# These can leak wallet keys, mint addresses, or player data — never commit.
# ---

# solana-example-wallet SQLite DB (AES-encrypted keys, but still — don't share)
**/wallets.db
**/wallets.db-journal

# Token UI / Agent UI persistent stores (mint addresses, signatures)
**/created_tokens.json
**/created_agents.json

# Client-side sandboxed icon cache (downloaded logos)
**/_iconcache_*.png
**/_iconcache_*.jpg
**/_iconcache_*.gif

# ---
# Credentials (never commit)
# ---

# Pinata API keys (if someone accidentally commits them to a local file)
pinata.key
pinata.secret
*.pinata.env

# ---
# MTA:SA / editor artefacts
# ---
.vscode/
.idea/
*.log
*.bak
*.swp
Thumbs.db
bash.exe.stackdump
